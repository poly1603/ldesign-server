# 忽略不必要的文件以减小 Docker 镜像大小

# 依赖
node_modules
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建产物
dist
build
*.tsbuildinfo

# 测试
coverage
.nyc_output
*.test.js
*.spec.js

# 环境变量
.env
.env.local
.env.*.local

# IDE
.vscode
.idea
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db

# 日志
logs
*.log

# 临时文件
tmp
temp
*.tmp

# 数据库
*.db
*.db-shm
*.db-wal

# Git
.git
.gitignore
.gitattributes

# 文档
README.md
CHANGELOG.md
*.md

# 配置文件（可选）
.eslintrc*
.prettierrc*
jest.config.*
vitest.config.*
tsconfig*.json














































