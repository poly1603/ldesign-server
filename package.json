{
  "name": "@ldesign/server",
  "version": "1.0.0",
  "type": "module",
  "description": "LDesign 后台接口服务 - 提供 Node 版本管理、Git 环境检测、项目管理等功能",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ldesign-server-dev": "./bin/dev.mjs",
    "ldesign-server-start": "./bin/start.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build && node scripts/postbuild.mjs",
    "build:clean": "node scripts/clean.mjs && pnpm build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "dev:tsx": "tsx watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "start:pm2:prod": "pm2 start ecosystem.config.js --env production",
    "stop:pm2": "pm2 stop ecosystem.config.js",
    "reload:pm2": "pm2 reload ecosystem.config.js",
    "monitor:pm2": "pm2 monit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:cov": "vitest --coverage",
    "test:e2e": "vitest --config vitest.e2e.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "node scripts/clean.mjs",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ldesign",
    "server",
    "nestjs",
    "api",
    "node-version-manager",
    "git",
    "project-management"
  ],
  "author": "LDesign Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@ldesign/git": "workspace:*",
    "@ldesign/node-manager": "workspace:*",
    "@ldesign/project-manager": "workspace:*",
    "@ldesign/shared": "workspace:*",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.1.0",
    "cache-manager": "^7.2.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.5"
  }
}
